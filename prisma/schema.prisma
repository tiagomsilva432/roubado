generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model musica {
  id       Int      @id @default(autoincrement())
  titulo   String   @db.VarChar(200)
  artista  String   @db.VarChar(200)
  genero   String   @db.VarChar(50)
  ano      Int
  favorita Boolean? @default(false)
}
